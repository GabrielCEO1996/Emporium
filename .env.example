# ─────────────────────────────────────────────────────────────────────────────
# Emporium — Environment Variables
#
# Copy this file to `.env.local` and fill in real values. NEVER commit
# `.env.local` (it's in .gitignore). For Vercel deployments set these in
# Project Settings → Environment Variables, separately for Production /
# Preview / Development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# From: https://supabase.com → Project → Settings → API
# - NEXT_PUBLIC_SUPABASE_URL is safe to expose to the browser
# - NEXT_PUBLIC_SUPABASE_ANON_KEY is the publishable anon key (safe)
# - SUPABASE_SERVICE_ROLE_KEY bypasses RLS — server-side only, NEVER expose
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ── Site URL (REQUIRED) ──────────────────────────────────────────────────────
# Used by transactional emails (links back to facturas / pedidos) and Stripe
# success/cancel redirects. Must be https in production. Locally use
# http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe (OPTIONAL — checkout flow) ────────────────────────────────────────
# From: https://dashboard.stripe.com → Developers → API keys
# - STRIPE_SECRET_KEY: server-only secret. Use sk_test_... for development,
#   sk_live_... for production. Required for /api/checkout to create sessions.
# - STRIPE_WEBHOOK_SECRET: from Dashboard → Webhooks → endpoint → "Reveal
#   signing secret". Required for /api/webhook/stripe to verify event
#   signatures. Leave blank to disable Stripe; checkout will return a 503
#   "Stripe no configurado".
# - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: not used by the current server-side
#   checkout flow (we redirect to session.url). Kept here for the day we
#   add Stripe Elements / payment intents on the client. Safe to leave blank.
# API version pinned to 2025-08-27.basil — stripe SDK ^18 (do not bump
# blindly; see README "Stripe API version" section).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Resend (OPTIONAL — transactional email) ──────────────────────────────────
# From: https://resend.com → API Keys
# Powers /api/email/factura, /api/email/nueva-orden, and the Stripe webhook
# email trigger. Leave blank to disable email; sends become no-ops with a
# console.warn.
RESEND_API_KEY=

# ── Anthropic (OPTIONAL — AI catalog assistant) ──────────────────────────────
# From: https://console.anthropic.com → API Keys
# Powers /api/tienda/chat (the in-store recommendation chat for compradores).
# Leave blank to hide the chat UI on the tienda.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────────────
# - .env.local is gitignored (.gitignore: .env*.local) — never commit it.
# - Vercel automatically loads vars from Project Settings; .env.local is
#   ignored in deployed builds.
# - To rotate any secret: update the source service first, then update Vercel
#   + .env.local, then redeploy. NEVER hardcode keys in code.
# - The Stripe key validator in src/lib/stripe.ts treats anything matching
#   "placeholder" or shorter than 20 chars as "not configured", so leaving the
#   value as the literal string `sk_test_placeholder` will also disable Stripe.
# ─────────────────────────────────────────────────────────────────────────────
