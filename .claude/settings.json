{
  "skills": {
    "autoLoad": false,
    "loadOnDemand": true,
    "cache": true
  },
  "context": {
    "cacheSkills": true,
    "prioritizeRecentFiles": true,
    "excludeFromContext": [
      "node_modules",
      ".next",
      "public",
      "*.lock",
      "*.log"
    ]
  },
  "performance": {
    "skipNodeModules": true,
    "skipBuildArtifacts": true,
    "focusOnSrc": true
  }
}
